{
  "id": "fathippo-context-engine",
  "name": "FatHippo Context Engine",
  "version": "0.1.0",
  "kind": "context-engine",
  "description": "Encrypted agent memory with semantic search, Dream Cycle synthesis, and tiered intelligence",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "type": "string",
        "description": "FatHippo API key"
      },
      "baseUrl": {
        "type": "string",
        "description": "FatHippo API base URL",
        "default": "https://www.fathippo.com/api"
      },
      "injectCritical": {
        "type": "boolean",
        "description": "Auto-inject critical memories",
        "default": true
      },
      "injectLimit": {
        "type": "number",
        "description": "Maximum memories to inject per turn",
        "default": 20
      },
      "captureUserOnly": {
        "type": "boolean",
        "description": "Only capture user messages (avoid self-poisoning)",
        "default": true
      },
      "dreamCycleOnCompact": {
        "type": "boolean",
        "description": "Run Dream Cycle during compaction instead of lossy summarization",
        "default": true
      },
      "cognitiveEnabled": {
        "type": "boolean",
        "description": "Enable trace capture, constraints, and cognitive context",
        "default": true
      },
      "cognitiveHeartbeatEnabled": {
        "type": "boolean",
        "description": "Run extraction and skill synthesis on heartbeat turns",
        "default": true
      },
      "shareEligibleByDefault": {
        "type": "boolean",
        "description": "Allow sanitized traces to contribute to shared global patterns",
        "default": true
      },
      "conversationId": {
        "type": "string",
        "description": "Scope memories to a specific conversation/project (null = derive from session)"
      }
    },
    "required": ["apiKey"]
  },
  "uiHints": {
    "apiKey": {
      "label": "API Key",
      "sensitive": true,
      "placeholder": "mem_..."
    },
    "baseUrl": {
      "label": "API Base URL",
      "advanced": true
    },
    "injectCritical": {
      "label": "Inject Critical Memories"
    },
    "injectLimit": {
      "label": "Injection Limit"
    },
    "captureUserOnly": {
      "label": "Capture User Messages Only"
    },
    "dreamCycleOnCompact": {
      "label": "Dream Cycle on Compact"
    },
    "cognitiveEnabled": {
      "label": "Enable Cognitive Loop"
    },
    "cognitiveHeartbeatEnabled": {
      "label": "Heartbeat Extraction"
    },
    "shareEligibleByDefault": {
      "label": "Shared Learning"
    },
    "conversationId": {
      "label": "Conversation ID",
      "advanced": true
    }
  }
}
