{
  "name": "fathippo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:packages && next build --webpack",
    "build:packages": "npm run build --workspaces --if-present --include-workspace-root=false",
    "db:migrate": "node scripts/db-migrate.mjs",
    "preflight:deploy": "node scripts/preflight-deploy.mjs",
    "smoke:deploy": "node scripts/post-deploy-smoke.mjs",
    "db:migrate:status": "node scripts/db-migrate.mjs --status",
    "embeddings:reindex": "node scripts/reindex-embeddings.mjs",
    "memory:quality": "node scripts/nightly_memory_quality.mjs",
    "memory:quality:apply": "node scripts/nightly_memory_quality.mjs --apply",
    "memory:auto-dream": "node scripts/auto_dream_lite.mjs",
    "memory:auto-dream:apply": "node scripts/auto_dream_lite.mjs --apply",
    "memory:topic-graph": "node scripts/topic_graph_maintenance.mjs",
    "memory:topic-graph:apply": "node scripts/topic_graph_maintenance.mjs --apply",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint",
    "check:examples": "./node_modules/.bin/tsc -p examples/tsconfig.json --noEmit",
    "check:cognitive-launch": "./node_modules/.bin/tsc --noEmit && ./node_modules/.bin/vitest run --config packages/cognitive-engine/vitest.config.ts packages/cognitive-engine/src/eval-harness.test.ts packages/cognitive-engine/src/evidence-weighting.test.ts packages/cognitive-engine/src/adaptive-policy.test.ts packages/cognitive-engine/src/adaptive-policy.e2e.test.ts packages/cognitive-engine/src/tool-workflow-strategy.test.ts packages/cognitive-engine/src/tool-workflow-strategy.e2e.test.ts packages/cognitive-engine/src/application-attribution.e2e.test.ts packages/cognitive-engine/src/shared-learning-settings.e2e.test.ts packages/cognitive-engine/src/api-key-scopes.e2e.test.ts packages/cognitive-engine/src/entitlements.e2e.test.ts packages/cognitive-engine/src/operational-hardening.e2e.test.ts packages/cognitive-engine/src/alert-delivery.test.ts packages/cognitive-engine/src/operational-alert-dispatch.test.ts packages/cognitive-engine/src/request-throttle.test.ts packages/cognitive-engine/src/admin-auth.test.ts packages/cognitive-engine/src/cognitive-privacy.e2e.test.ts packages/cognitive-engine/src/heartbeat-thresholds.test.ts packages/cognitive-engine/src/tool-result-parsing.test.ts packages/cognitive-engine/src/org-patterns.e2e.test.ts packages/cognitive-engine/src/org-governance.e2e.test.ts && npm run check:examples"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.38.2",
    "@libsql/client": "^0.17.0",
    "@radix-ui/react-slider": "^1.3.6",
    "@upstash/redis": "^1.36.3",
    "@xenova/transformers": "^2.17.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^11.18.0",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "openai": "^6.25.0",
    "pdf-parse-new": "^2.0.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0",
    "tiktoken": "^1.0.22",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^1.6.1"
  },
  "packageManager": "npm@10.8.0",
  "license": "Apache-2.0"
}
