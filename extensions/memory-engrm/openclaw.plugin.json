{
  "id": "memory-engrm",
  "name": "Memory (Engrm)",
  "description": "Cloud-native encrypted memory with auto-recall, auto-capture, and tiered intelligence",
  "kind": "memory",
  "version": "0.1.0",
  "author": "Engrm",
  "repository": "https://github.com/jscianna/engrm",
  "configSchema": {
    "type": "object",
    "properties": {
      "apiKey": {
        "type": "string",
        "description": "Engrm API key (mem_xxx)"
      },
      "baseUrl": {
        "type": "string",
        "default": "https://www.engrm.xyz/api/v1",
        "description": "Engrm API base URL"
      },
      "autoRecall": {
        "type": "boolean",
        "default": true,
        "description": "Auto-inject relevant memories before agent starts"
      },
      "autoCapture": {
        "type": "boolean",
        "default": true,
        "description": "Auto-extract insights after conversations"
      },
      "captureMaxChars": {
        "type": "number",
        "default": 2000,
        "description": "Max chars for auto-capture"
      },
      "recallLimit": {
        "type": "number",
        "default": 5,
        "description": "Max memories to inject"
      },
      "minRecallScore": {
        "type": "number",
        "default": 0.3,
        "description": "Min similarity score for recall"
      }
    },
    "required": ["apiKey"]
  },
  "uiHints": {
    "apiKey": { "label": "API Key", "sensitive": true, "placeholder": "mem_xxx" },
    "autoRecall": { "label": "Auto-Recall", "description": "Inject relevant memories automatically" },
    "autoCapture": { "label": "Auto-Capture", "description": "Store insights automatically" }
  }
}
